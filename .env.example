# Provider: openai | vertex
PROVIDER=openai

# OpenAI
MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Vertex (Gemini)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-pro

# Paths
DOCS_PATH=docs
DATA_DIR=data

# Retrieval
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_DENSE=50
TOP_K_FUSED=20
TOP_K_FINAL=8
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6
RERANK_MODEL=BAAI/bge-reranker-base
MIN_CTX_SCORE=0.35
ADAPTIVE_K_MULTIPLIER=1.5

# Features
ENABLE_QUERY_EXPANSION=true
ENABLE_MULTI_QUERY=true
ENABLE_HYDE=true
ENABLE_HYPE=true
ENABLE_COMPRESSION=true
ENABLE_TRACING=true

# Compression / generation limits
MAX_CONTEXT_TOKENS=4096
COMPRESSION_MAX_SENTENCES=12

# Enterprise / API
API_KEY=
RATE_LIMIT_PER_MINUTE=120
JSON_LOGGING=false
LLM_TIMEOUT_SECONDS=120
MAX_REQUEST_BODY_BYTES=1048576

# Phase 2 retrieval
ENABLE_GRAPH_RAG=false
ENABLE_AGENTIC_RETRIEVAL=false
AGENTIC_MAX_STEPS=3
ENABLE_PDF_INGEST=true
